section data vars at $1000
    idx: byte = 0
    arr: byte[16] = {}
    out: word = 0
end

section code boot at $0000
  export func main()
    ping 1
    getb arr[idx]
    ld a, l
    getw 9
    push de
    ex de, hl
    addr hl, out
    ld (hl), e
    inc hl
    ld (hl), d
    ex de, hl
    pop de
  end
end
