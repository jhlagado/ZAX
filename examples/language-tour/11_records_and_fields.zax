type Pair
  lo: byte
  hi: byte
end

section data vars at $1000
  pair_buf: Pair = { lo: 0, hi: 0 }
end

func write_pair(lo_value: byte, hi_value: byte)
  a := lo_value
  pair_buf.lo := a
  a := hi_value
  pair_buf.hi := a
end

func read_pair_word(): HL
  move l, pair_buf.lo
  move h, pair_buf.hi
end

export func main()
  var
    pair_alias = pair_buf
  end

  write_pair 1, 2
  a := pair_alias.lo
  read_pair_word
end
