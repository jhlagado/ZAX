op clear_carry()
  xor a
end

op add16(dst: HL, src: reg16)
  clear_carry
  adc hl, src
end

op read_byte(dst: reg8, source_mem: mem8)
  ld dst, source_mem
end

section data vars at $1000
  sample_byte: byte = 7
  sample_word: word = 100
end

func add_to_sample(delta_word: word): HL
  move hl, sample_word
  move de, delta_word
  add16 hl, de
end

export func main()
  var
    result_word: word = 0
  end

  read_byte a, (sample_byte)
  add_to_sample 23
  move result_word, hl
end
