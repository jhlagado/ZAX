section data vars at $2000
    glob_w: word = $BEEF
end

section code boot at $0100
  export func touch_scalar_word_glob(): HL
    ld hl, glob_w
    push de
    ex de, hl
    addr hl, glob_w
    ld (hl), e
    inc hl
    ld (hl), d
    ex de, hl
    pop de
  end

  export func main()
    touch_scalar_word_glob
  end
end
