section data vars at $2000
    glob_words: word[8] = { $3001,$3002,$3003,$3004,$3005,$3006,$3007,$3008 }
end

section code boot at $0100
  export func word_glob_reg16(idx: word): HL
    move hl, idx
    move de, glob_words[hl]
    move glob_words[hl], de
    ex de, hl
  end

  export func main()
    word_glob_reg16 $0004
  end
end
