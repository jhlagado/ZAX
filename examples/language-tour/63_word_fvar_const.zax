section data vars at $2000
    glob_words: word[8] = { $4001,$4002,$4003,$4004,$4005,$4006,$4007,$4008 }
end

section code boot at $0100
  export func word_fvar_const(arr: word[]): HL
    ld hl, arr[2]
    push de
    ex de, hl
    addr hl, arr[3]
    ld (hl), e
    inc hl
    ld (hl), d
    ex de, hl
    pop de
  end

  export func main()
    word_fvar_const glob_words
  end
end
