section data vars at $2000
    glob_words: word[8] = { $6001,$6002,$6003,$6004,$6005,$6006,$6007,$6008 }
end

section code boot at $0100
  export func word_fvar_reg16(arr: word[], idx: word): HL
    move hl, idx
    move bc, arr[hl]
    move arr[hl], bc
    ld h, b
    ld l, c
  end

  export func main()
    word_fvar_reg16 glob_words, $0006
  end
end
