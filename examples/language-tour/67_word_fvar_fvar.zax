section data vars at $2000
    glob_words: word[8] = { $8001,$8002,$8003,$8004,$8005,$8006,$8007,$8008 }
end

section code boot at $0100
  export func word_fvar_fvar(arr: word[], idx_word: word): HL
    move de, arr[idx_word]
    move arr[idx_word], de
    ex de, hl
  end

  export func main()
    word_fvar_fvar glob_words, $0005
  end
end
