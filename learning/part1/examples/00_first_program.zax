; Chapter 3 example: load a value into A, store it to a named memory location

const StoredValue = $42          ; the value we will store

export func main()
  ld a, StoredValue              ; A = $42
  ld (result), a                 ; write A to the byte named 'result'
end

section data state at $8000
  result: byte = 0               ; one byte of storage, initialized to zero
end
