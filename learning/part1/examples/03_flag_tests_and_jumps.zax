; Chapter 04 example: cp, or a, conditional jp, label-based counted loop, and logical ops

const Limit = 5                  ; loop will run this many times

section data vars at $8000
  counter: byte = 0              ; loop counter stored in RAM
  found:   byte = 0              ; set to 1 when A reaches Limit
end

export func main()
  ; --- Part 1: conditional branch on a single comparison ---
  ld a, Limit                    ; A = 5
  cp 5                           ; compare A with 5; sets Z if equal
  jp nz, not_equal               ; jump if A != 5
  ld a, 1
  ld (found), a                  ; found = 1 (A was equal to Limit)
  jp done_compare
not_equal:
  ld a, 0
  ld (found), a                  ; found = 0 (A was not equal to Limit)
done_compare:

  ; --- Part 2: test whether A is zero using 'or a' ---
  ld a, 0
  or a                           ; sets Z if A == 0, no other change to A
  jp z, was_zero                 ; jump if A == 0
  jp skip_zero
was_zero:
  ld a, $AA                      ; mark register to show we took this path
skip_zero:

  ; --- Part 3: simple counted loop using dec / jp nz ---
  ld b, Limit                    ; B = loop count
loop_top:
  ld a, (counter)
  inc a
  ld (counter), a                ; counter++
  dec b                          ; B--; sets Z when B reaches 0
  jp nz, loop_top                ; repeat while B != 0

  ; --- Part 4: logical operations (and, or, xor) ---
  ld a, $F3                      ; A = %11110011
  and $0F                        ; A = %00000011; upper four bits cleared; Z clear, C clear

  ld a, $03                      ; A = %00000011
  or $80                         ; A = %10000011; bit 7 set; Z clear

  ld a, $FF                      ; A = %11111111
  xor $0F                        ; A = %11110000; lower four bits flipped; Z clear

  xor a                          ; A = 0; Z is set; C is clear
end
