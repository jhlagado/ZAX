{
  "name": "zax",
  "private": true,
  "version": "0.0.0",
  "description": "ZAX assembler (Node.js)",
  "license": "GPL-3.0-only",
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pretest": "mkdir -p coverage/.tmp",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ci:coverage-core": "vitest run --coverage --exclude 'test/cli_*.test.ts' --exclude 'test/pr312_expected_trace_corpus.test.ts'",
    "test:ci:slow-reliability": "vitest run --no-file-parallelism --maxWorkers=1 --minWorkers=1 --testTimeout=20000 --hookTimeout=300000 test/cli_acceptance_matrix_strictness.test.ts test/cli_artifacts.test.ts test/cli_case_style_lint.test.ts test/cli_contract_matrix.test.ts test/cli_determinism_contract.test.ts test/cli_failure_contract_matrix.test.ts test/cli_path_parity_contract.test.ts test/cli_zax_smoke.test.ts",
    "test:watch": "vitest",
    "format": "prettier -w .",
    "format:check": "prettier -c .",
    "check:source-file-sizes": "node scripts/check-source-file-sizes.mjs",
    "zax": "npm run build && node dist/src/cli.js",
    "regen:language-tour": "bash scripts/regenerate-language-tour.sh",
    "regen:codegen-corpus": "node scripts/regenerate-codegen-corpus.mjs",
    "book": "bash scripts/build-book.sh"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "@vitest/coverage-v8": "^2.1.9",
    "prettier": "^3.5.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  }
}
