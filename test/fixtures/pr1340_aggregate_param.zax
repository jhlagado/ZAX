type TreeNode
  value: byte
  left: addr
  right: addr
end

section data vars at $8000
  root: TreeNode
end

func search(node: TreeNode, target: byte): HL
  a := node.value
  b := target
  cp b
  if Z
    ld hl, 1
    ret
  end
  hl := node.left
  search hl, target
end

export func main()
  hl := @root
  search hl, 5
end
