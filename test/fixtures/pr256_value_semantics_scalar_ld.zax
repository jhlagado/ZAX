section code at $0000
section var at $1000

globals
  wordVar: word
  byteVar: byte
  arr: byte[4]

export func main(arg: byte): void
  ld a, byteVar
  ld byteVar, a
  ld hl, wordVar
  push de
  ex de, hl
  addr hl, wordVar
  ld (hl), e
  inc hl
  ld (hl), d
  ex de, hl
  pop de
  ld a, arr[1]
  ld arr[2], a
  ld a, arg
  ld arg, a
end
