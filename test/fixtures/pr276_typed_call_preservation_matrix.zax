extern func getb(seed: byte): HL at $1234
extern func getw(seed: word): HL at $1240
extern func ping(seed: byte): HL at $1250

section data vars at $1000
    out: word = 0
end

section code boot at $0000
  export func main()
    ping 1
    getb 7
    ld a, l
    getw 9
    out := hl
    ret
  end
end
