section data vars at $1000
    gword: word = 0
    gbyte: byte = 0
end

section code boot at $0000
  export func touch(v: word)
    ret
  end

  export func main(arg0: word)
    var
      localw: word
      localb: byte
    end
    move hl, arg0
    move localw, hl
    move hl, localw
    move gword, hl
    move a, localb
    move gbyte, a
    touch gword
    ret
  end
end
