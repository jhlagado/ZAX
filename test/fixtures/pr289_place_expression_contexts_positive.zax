type Pair
  lo: byte
  hi: byte
end

section data vars at $1000
    p: Pair = { lo: 0, hi: 0 }
    idx: byte = 0
    arr: byte[8] = [0, 0, 0, 0, 0, 0, 0, 0]
end

op readAddr(addr: byte)
  move a, addr
end

export func main()
  move a, p.lo
  move p.lo, a
  move a, arr[idx]
  move arr[idx], a

  move a, p.lo
  move p.lo, a
  move a, arr[idx]
  move arr[idx], a

  readAddr p.lo
  readAddr arr[idx]
  ret
end
