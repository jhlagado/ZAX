type Pair
  lo: byte
  hi: byte
end

section data vars at $1000
    p: Pair = { lo: 0, hi: 0 }
    idx: byte = 0
    arr: byte[8] = [0, 0, 0, 0, 0, 0, 0, 0]
end

op readAddr(addr: ea)
  a := addr
end

export func main()
  a := p.lo
  p.lo := a
  a := arr[idx]
  arr[idx] := a

  a := p.lo
  p.lo := a
  a := arr[idx]
  arr[idx] := a

  readAddr p.lo
  readAddr arr[idx]
  ret
end
