func add_words(left_word: word, right_word: word): HL
  ld hl, left_word
  ld de, right_word
  add hl, de
end

func bump_byte(input_byte: byte): HL
  var
    temp_word: word = 0
  end

  ld l, input_byte
  ld h, 0
  inc l
  push de
  ex de, hl
  addr hl, temp_word
  ld (hl), e
  inc hl
  ld (hl), d
  ex de, hl
  pop de
  ld hl, temp_word
end

export func main()
  var
    result_word: word = 0
  end

  add_words 10, 20
  push de
  ex de, hl
  addr hl, result_word
  ld (hl), e
  inc hl
  ld (hl), d
  ex de, hl
  pop de

  bump_byte 7
end
