section data vars at $1000
    gw: word[4] = { $1111, $2222, $3333, $4444 }
end

export func main()
  var
    idx8: byte = $01
    idxw: word = $0002
    tmp: word = $5555
  end

  ; reg8 index load/store
  move hl, gw[idx8]
  move gw[idx8], hl

  ; reg16 index load/store (HL as index)
  move hl, idxw
  move de, gw[hl]
  move gw[hl], de

  ; store tmp via reg8 index
  move hl, tmp
  move gw[idx8], hl
end
