type Rec
  field: byte
end

section data vars at $1000
  count: byte = $ff
  total: word = $ffff
  bytes: byte[4] = [0, 1, 2, 3]
  words: word[4] = [0, 1, 2, 3]
  rec: Rec
end

export func main()
  var
    local_count: byte = $ff
    local_total: word = $ffff
  end

  succ local_count
  jr z, local_byte_zero
local_byte_zero:

  pred count
  jr z, global_byte_zero
global_byte_zero:

  ld a, 1
  succ bytes[a]
  jr z, indexed_byte_zero
indexed_byte_zero:

  pred rec.field
  jr z, field_byte_zero
field_byte_zero:

  succ local_total
  jr z, local_word_zero
local_word_zero:

  pred total
  jr z, global_word_zero
global_word_zero:

  hl := 1
  succ words[hl]
  jr z, indexed_word_zero
indexed_word_zero:
  ret
end
