section data vars at $2000
    glob_bytes: byte[8] = { 0,1,2,3,4,5,6,7 }
end

section code boot at $0100
  export func byte_fvar_reg16(arr: byte[], idx: word): HL
    hl := idx
    a := arr[hl]
    arr[hl] := a
    ld h, 0
    ld l, a
  end

  export func main()
    byte_fvar_reg16 glob_bytes, $0006
  end
end
