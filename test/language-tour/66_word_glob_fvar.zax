section data vars at $2000
    glob_words: word[8] = { $7001,$7002,$7003,$7004,$7005,$7006,$7007,$7008 }
end

section code boot at $0100
  export func word_glob_fvar(idx_word: word): HL
    hl := glob_words[idx_word]
    glob_words[idx_word] := hl
  end

  export func main()
    word_glob_fvar $0002
  end
end
